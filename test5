# 第一句：定义一个函数来演示程序性知识（如何做）
def procedural_knowledge_demo():
    """
    程序性知识：关于"如何做"的知识，表现为一系列的操作步骤
    """
    # 这里是具体的操作步骤，演示如何完成任务
    steps = ["打开视频", "定位重点", "观看演示", "动手实践", "完成学习"]
    return "程序性知识演示：执行步骤 -> " + " → ".join(steps)

# 第二句：通过循环结构展示程序性知识的流程控制
for step in ["初始化视频", "锚定程序性知识节点", "执行操作序列", "获得技能"]:
    print(f"程序性知识教学: {step} - 这是关于'如何做'的过程性指导")
